generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  user
  admin
}

enum RepairLevel {
  econom
  standard
  premium
}

enum SurfaceType {
  wall
  floor
  ceiling
}

enum CompatibilityType {
  required
  recommended
  incompatible
}

enum EstimateStatus {
  draft
  saved
  exported
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id                String   @id @default(uuid()) @db.Uuid

  email             String   @unique @db.VarChar(255)

  passwordHash      String?  @map("password_hash") @db.VarChar(255)

  name              String?  @db.VarChar(255)

  avatar            String?  @db.Text

  googleId          String?  @unique @map("google_id")

  role              UserRole @default(user)

  emailVerified     Boolean  @default(false) @map("email_verified")

  createdAt         DateTime @default(now()) @map("created_at")

  updatedAt         DateTime @updatedAt @map("updated_at")

  calculations      Calculation[]

  estimates         Estimate[]

  comparisons       Comparison[]

  articles          Article[]

  logs              UserActionLog[]

  @@map("users")
}

//////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////

model Category {
  id                String   @id @default(uuid()) @db.Uuid

  name              String   @unique @db.VarChar(255)

  slug              String   @unique @db.VarChar(255)

  createdAt         DateTime @default(now()) @map("created_at")

  materials         Material[]

  @@map("categories")
}

//////////////////////////////////////////////////////
// MANUFACTURERS
//////////////////////////////////////////////////////

model Manufacturer {
  id                String   @id @default(uuid()) @db.Uuid

  name              String   @unique @db.VarChar(255)

  country           String?  @db.VarChar(100)

  createdAt         DateTime @default(now()) @map("created_at")

  materials         Material[]

  @@map("manufacturers")
}

//////////////////////////////////////////////////////
// MATERIALS
//////////////////////////////////////////////////////

model Material {
  id                      String   @id @default(uuid()) @db.Uuid

  name                    String   @db.VarChar(255)

  slug                    String   @unique @db.VarChar(255)

  categoryId              String   @map("category_id") @db.Uuid

  manufacturerId          String   @map("manufacturer_id") @db.Uuid

  repairLevel             RepairLevel @map("repair_level")

  surfaceType             SurfaceType @map("surface_type")

  price                   Decimal  @db.Decimal(10, 2)

  consumptionPerM2        Decimal  @map("consumption_per_m2") @db.Decimal(10, 3)

  unit                    String   @db.VarChar(50)

  packageQuantity         Decimal  @map("package_quantity") @db.Decimal(10, 2)

  packageUnit             String   @map("package_unit") @db.VarChar(50)

  stockQuantity           Int      @default(0) @map("stock_quantity")

  description             String?  @db.Text

  imageUrl                String?  @map("image_url") @db.Text

  isAvailable             Boolean  @default(true) @map("is_available")

  isActive                Boolean  @default(true) @map("is_active")

  createdAt               DateTime @default(now()) @map("created_at")

  updatedAt               DateTime @updatedAt @map("updated_at")

  deletedAt               DateTime? @map("deleted_at")

  category                Category @relation(fields: [categoryId], references: [id])

  manufacturer            Manufacturer @relation(fields: [manufacturerId], references: [id])

  properties              MaterialProperty[]

  compatibilities         MaterialCompatibility[] @relation("MaterialCompatibilities")

  compatibleWith          MaterialCompatibility[] @relation("CompatibleMaterials")

  alternatives            MaterialAlternative[] @relation("MaterialAlternatives")

  alternativeFor          MaterialAlternative[] @relation("AlternativeMaterials")

  variantItems            VariantItem[]

  estimateItems           EstimateItem[]

  comparisons             Comparison[]

  logs                    UserActionLog[]

  @@index([categoryId])

  @@index([manufacturerId])

  @@index([repairLevel])

  @@index([surfaceType])

  @@map("materials")
}

//////////////////////////////////////////////////////
// MATERIAL PROPERTIES
//////////////////////////////////////////////////////

model MaterialProperty {
  id                String   @id @default(uuid()) @db.Uuid

  materialId        String   @map("material_id") @db.Uuid

  name              String   @db.VarChar(255)

  value             String   @db.VarChar(255)

  type              String   @db.VarChar(50)

  unit              String?  @db.VarChar(50)

  material          Material @relation(fields: [materialId], references: [id])

  @@map("material_properties")
}

//////////////////////////////////////////////////////
// MATERIAL COMPATIBILITY
//////////////////////////////////////////////////////

model MaterialCompatibility {
  id                      String   @id @default(uuid()) @db.Uuid

  materialId              String   @map("material_id") @db.Uuid

  compatibleMaterialId    String   @map("compatible_material_id") @db.Uuid

  compatibilityType       CompatibilityType @map("compatibility_type")

  reason                  String?  @db.Text

  material                Material @relation("MaterialCompatibilities", fields: [materialId], references: [id])

  compatibleMaterial      Material @relation("CompatibleMaterials", fields: [compatibleMaterialId], references: [id])

  @@map("material_compatibility")
}

//////////////////////////////////////////////////////
// MATERIAL ALTERNATIVES
//////////////////////////////////////////////////////

model MaterialAlternative {
  id                        String   @id @default(uuid()) @db.Uuid

  materialId                String   @map("material_id") @db.Uuid

  alternativeMaterialId     String   @map("alternative_material_id") @db.Uuid

  material                  Material @relation("MaterialAlternatives", fields: [materialId], references: [id])

  alternativeMaterial       Material @relation("AlternativeMaterials", fields: [alternativeMaterialId], references: [id])

  @@map("material_alternatives")
}

//////////////////////////////////////////////////////
// CALCULATIONS
//////////////////////////////////////////////////////

model Calculation {
  id                  String   @id @default(uuid()) @db.Uuid

  userId              String?  @map("user_id") @db.Uuid

  roomType            String   @map("room_type") @db.VarChar(100)

  surfaceType         SurfaceType @map("surface_type")

  length              Float

  width               Float

  height              Float?

  area                Float

  perimeter           Float

  budget              Decimal? @db.Decimal(10, 2)

  repairLevel         RepairLevel @map("repair_level")

  createdAt           DateTime @default(now()) @map("created_at")

  user                User? @relation(fields: [userId], references: [id])

  variants            Variant[]

  estimates           Estimate[]

  @@map("calculations")
}

//////////////////////////////////////////////////////
// VARIANTS
//////////////////////////////////////////////////////

model Variant {
  id                  String   @id @default(uuid()) @db.Uuid

  calculationId       String   @map("calculation_id") @db.Uuid

  title               String   @db.VarChar(100)

  totalPrice          Decimal  @map("total_price") @db.Decimal(10, 2)

  fitsBudget          Boolean  @map("fits_budget")

  createdAt           DateTime @default(now()) @map("created_at")

  calculation         Calculation @relation(fields: [calculationId], references: [id])

  items               VariantItem[]

  @@map("variants")
}

//////////////////////////////////////////////////////
// VARIANT ITEMS
//////////////////////////////////////////////////////

model VariantItem {
  id                  String   @id @default(uuid()) @db.Uuid

  variantId           String   @map("variant_id") @db.Uuid

  materialId          String   @map("material_id") @db.Uuid

  quantity            Float

  packageCount        Int      @map("package_count")

  unitPrice           Decimal  @map("unit_price") @db.Decimal(10, 2)

  totalPrice          Decimal  @map("total_price") @db.Decimal(10, 2)

  variant             Variant @relation(fields: [variantId], references: [id])

  material            Material @relation(fields: [materialId], references: [id])

  @@map("variant_items")
}

//////////////////////////////////////////////////////
// ESTIMATES
//////////////////////////////////////////////////////

model Estimate {
  id                  String   @id @default(uuid()) @db.Uuid

  userId              String   @map("user_id") @db.Uuid

  calculationId       String   @map("calculation_id") @db.Uuid

  status              EstimateStatus @default(draft)

  totalPrice          Decimal  @map("total_price") @db.Decimal(10, 2)

  createdAt           DateTime @default(now()) @map("created_at")

  user                User @relation(fields: [userId], references: [id])

  calculation         Calculation @relation(fields: [calculationId], references: [id])

  items               EstimateItem[]

  @@map("estimates")
}

//////////////////////////////////////////////////////
// ESTIMATE ITEMS
//////////////////////////////////////////////////////

model EstimateItem {
  id                  String   @id @default(uuid()) @db.Uuid

  estimateId          String   @map("estimate_id") @db.Uuid

  materialId          String   @map("material_id") @db.Uuid

  quantity            Float

  packageCount        Int      @map("package_count")

  price               Decimal  @db.Decimal(10, 2)

  total               Decimal  @db.Decimal(10, 2)

  estimate            Estimate @relation(fields: [estimateId], references: [id])

  material            Material @relation(fields: [materialId], references: [id])

  @@map("estimate_items")
}

//////////////////////////////////////////////////////
// COMPARISONS
//////////////////////////////////////////////////////

model Comparison {
  id                  String   @id @default(uuid()) @db.Uuid

  userId              String   @map("user_id") @db.Uuid

  materialId          String   @map("material_id") @db.Uuid

  createdAt           DateTime @default(now()) @map("created_at")

  user                User @relation(fields: [userId], references: [id])

  material            Material @relation(fields: [materialId], references: [id])

  @@map("comparisons")
}

//////////////////////////////////////////////////////
// ARTICLES
//////////////////////////////////////////////////////

model Article {
  id                  String   @id @default(uuid()) @db.Uuid

  title               String   @db.VarChar(255)

  slug                String   @unique @db.VarChar(255)

  content             String   @db.Text

  authorId            String?  @map("author_id") @db.Uuid

  createdAt           DateTime @default(now()) @map("created_at")

  updatedAt           DateTime @updatedAt @map("updated_at")

  author              User? @relation(fields: [authorId], references: [id])

  @@map("articles")
}

//////////////////////////////////////////////////////
// USER ACTION LOGS
//////////////////////////////////////////////////////

model UserActionLog {
  id                  String   @id @default(uuid()) @db.Uuid

  userId              String?  @map("user_id") @db.Uuid

  materialId          String?  @map("material_id") @db.Uuid

  action              String   @db.VarChar(100)

  ipAddress           String?  @map("ip_address") @db.VarChar(100)

  createdAt           DateTime @default(now()) @map("created_at")

  user                User? @relation(fields: [userId], references: [id])

  material            Material? @relation(fields: [materialId], references: [id])

  @@map("user_action_logs")
}

//////////////////////////////////////////////////////
// SETTINGS
//////////////////////////////////////////////////////

model Setting {
  id                  String   @id @default(uuid()) @db.Uuid

  key                 String   @unique @db.VarChar(100)

  value               String   @db.Text

  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("settings")
}